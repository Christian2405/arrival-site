{
  "expo": {
    "name": "Arrival AI",
    "slug": "arrival",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "arrival",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFF5"
    },
    "ios": {
      "bundleIdentifier": "com.arrivalcompany.arrival",
      "buildNumber": "2",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Arrival uses the camera to see equipment and help diagnose issues.",
        "NSMicrophoneUsageDescription": "Arrival uses the microphone for hands-free voice commands.",
        "NSPhotoLibraryUsageDescription": "Arrival uses your photo library to analyze images of equipment and job sites."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.arrivalcompany.arrival",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFF5"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "arrival",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "4fce28da-5d33-4da1-870e-d52d51d283e3"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Arrival needs camera access to see equipment and help diagnose issues."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Arrival needs microphone access for voice commands."
        }
      ],
      "expo-web-browser",
      [
        "@sentry/react-native",
        {
          "organization": "spheree",
          "project": "arrival-mobile"
        }
      ],
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      "expo-font"
    ],
    "owner": "christianfladgate"
  }
}
